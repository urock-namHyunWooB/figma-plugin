);

const buttonSolidContentIcononlySwitchClasses = cva(
  "[font-feature-settings:ss10_on] [font-family:Pretendard_JP] not-italic",
  {
    variants: {
      variant: {
        Primary: "font-semibold",
        Assistive: "font-medium",
      },
      size: {
        Large: "text-[16px] leading-[150%] tracking-[0.091px]",
        Medium: "text-[15px] leading-[146.7%] tracking-[0.144px]",
        Small: "text-[13px] leading-[138.5%] tracking-[0.252px]",
      },
      disable: {
        true: "",
        false: "",
      },
    },
    compoundVariants: [
      {
        variant: "Primary",
        disable: false,
        className:
          "text-[var(--Semantic-Static-White,_var(--Static-White,_#FFF))]",
      },
      {
        variant: "Primary",
        disable: true,
        className:
          "text-[var(--Semantic-Label-Assistive,_var(--Label-Assistive,_rgba(55,_56,_60,_0.28)))]",
      },
      {
        variant: "Assistive",
        disable: false,
        className:
          "text-[var(--Semantic-Label-Neutral,_var(--Label-Neutral,_rgba(46,_47,_51,_0.88)))]",
      },
      {
        variant: "Assistive",
        disable: true,
        className:
          "text-[var(--Semantic-Label-Assistive,_var(--Label-Assistive,_rgba(55,_56,_60,_0.28)))]",
      },
    ],
  }
);

const buttonSolidContentIcononlySwitchIconsIconsClasses = cva(
  "flex flex-col justify-center items-center",
  {
    variants: {
      size: {
        Large: "h-[24px]",
        Medium: "h-[20px]",
        Small: "h-[18px]",
      },
    },
  }
);

export default function Buttonsolid(props: ButtonsolidProps) {
  const {
    leadingIcon = null,
    trailingIcon = null,
    label = "텍스트",
    loading = false,
    variant = "Primary",
    size = "Large",
    iconOnly = false,
    disable = false,
    icon = null,
    ...restProps
  } = props;

  return (
    <button
      className={buttonSolidClasses({ size, variant, iconOnly, disable })}
      {...restProps}
    >
      {loading && !disable && (
        <div className={buttonSolidLoadingClasses({ size, iconOnly })}>
          <div className={circularCircularWrapperClasses({ size })}>
            <Circularcircular shapeBg="#FFFFFF" unionBg="#FFFFFF" />
          </div>
        </div>
      )}
      <div className={buttonSolidContentClasses({ loading, size })}>
        {iconOnly ? (
          <>
            {icon && (
              <div
                className={buttonSolidContentIcononlySwitchIconsIconsClasses({
                  size,
                })}
              >
                {icon}
              </div>
            )}
          </>
        ) : (
          <>
            {leadingIcon && (
              <div
                className={buttonSolidContentIcononlySwitchLeadingIconClasses({
                  size,
                })}
              >
                {leadingIcon}
              </div>
            )}
            {trailingIcon && (
              <div
                className={buttonSolidContentIcononlySwitchLeadingIconClasses({
                  size,
                })}
              >
                {trailingIcon}
              </div>
            )}
            {label && (
              <span
                className={buttonSolidContentIcononlySwitchClasses({
                  variant,
                  size,
                  disable,
                })}
              >
                {label}
              </span>
            )}
          </>
        )}
      </div>
    </button>
  );
}
"
`;
