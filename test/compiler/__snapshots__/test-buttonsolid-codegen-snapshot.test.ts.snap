"import React from "react";
import { cva } from "class-variance-authority";

interface CircularcircularProps {
  animate?: "False"; // default: "False"
  ratioVertical?: React.ReactNode; // default: null
  shapeBg?: string; // default: "#E1E2E4"
  unionBg?: string; // default: "#E1E2E4"
}

const Circularcircular_circularCircularClasses =
  "inline-flex h-full items-center gap-[10px] relative";

const Circularcircular_circularCircularRatioVerticalClasses =
  "flex flex-col items-start self-stretch overflow-hidden";

const Circularcircular_circularCircularShapeClasses =
  "w-[28px] h-[28px] absolute";

function Circularcircular(props: CircularcircularProps) {
  const {
    animate = "False",
    ratioVertical = null,
    shapeBg = "#E1E2E4",
    unionBg = "#E1E2E4",
    ...restProps
  } = props;

  return (
    <div className={Circularcircular_circularCircularClasses} {...restProps}>
      {ratioVertical && (
        <div className={Circularcircular_circularCircularRatioVerticalClasses}>
          {ratioVertical}
        </div>
      )}
      <div
        className={Circularcircular_circularCircularShapeClasses}
        style={{ background: shapeBg }}
      />
    </div>
  );
}

interface ButtonsolidOwnProps {
  leadingIcon?: React.ReactNode; // default: null
  trailingIcon?: React.ReactNode; // default: null
  label?: string; // default: "텍스트"
  loading?: boolean; // default: false
  variant?: "Primary" | "Assistive"; // default: "Primary"
  size?: "Small" | "Medium" | "Large"; // default: "Large"
  iconOnly?: boolean; // default: false
  disable?: boolean; // default: false
  icon?: React.ReactNode; // default: null
}

export interface ButtonsolidProps
  extends Omit<
      React.ButtonHTMLAttributes<HTMLButtonElement>,
      keyof ButtonsolidOwnProps
    >,
    ButtonsolidOwnProps {}

const buttonSolidClasses = cva(
  "inline-flex flex-col justify-center items-center overflow-hidden relative",
  {
    variants: {
      size: {
        Large: "rounded-[12px]",
        Medium: "rounded-[10px]",
        Small: "rounded-[8px]",
      },
      variant: {
        Assistive: "backdrop-blur-[32px]",
        Primary: "",
      },
      iconOnly: {
        true: "",
        false: "",
      },
      disable: {
        true: "",
        false: "",
      },
    },
    compoundVariants: [
      { size: "Large", iconOnly: false, className: "p-[12px_28px]" },
      { size: "Medium", iconOnly: false, className: "p-[9px_20px]" },
      { size: "Small", iconOnly: false, className: "p-[7px_14px]" },
      { size: "Large", iconOnly: true, className: "p-[12px]" },
      { size: "Medium", iconOnly: true, className: "p-[10px]" },
      { size: "Small", iconOnly: true, className: "p-[7px]" },
      {
        variant: "Primary",
        disable: false,
        className: "[background-color:var(--Primary-Normal,_#06F)]",
      },
      {
        variant: "Primary",
        disable: true,
        className: "[background-color:var(--Interaction-Disable,_#F4F4F5)]",
      },
      {
        variant: "Assistive",
        disable: false,
        className:
          "[background-color:var(--Fill-Normal,_rgba(112,_115,_124,_0.08))]",
      },
      {
        variant: "Assistive",
        disable: true,
        className: "[background-color:var(--Interaction-Disable,_#F4F4F5)]",
      },
    ],
  }
);

const buttonSolidLoadingClasses = cva(
  "flex justify-center items-center absolute flex-row",
  {
    variants: {
      size: {
        Small: "",
        Medium: "",
        Large: "",
      },
      iconOnly: {
        true: "",
        false: "",
      },
    },
    compoundVariants: [
      {
        size: "Large",
        iconOnly: false,
        className: "w-[42px] h-[24px] p-[3px_0]",
      },
      {
        size: "Medium",
        iconOnly: false,
        className: "w-[40px] h-[22px] p-[3px_0]",
      },
      {
