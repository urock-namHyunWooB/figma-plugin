{
  "name": "_",
  "version": "1.0.0",
  "type": "module",
  "description": "Your Figma Plugin",
  "main": "code.js",
  "scripts": {
    "build": "npm run build:plugin -- --mode development && npm run build:ui -- --mode development",
    "build:prod": "npm run build:plugin -- --mode production && npm run build:ui -- --mode production",
    "build:plugin": "vite build --config vite.plugin.config.ts",
    "build:ui": "vite build --config vite.ui.config.ts",
    "build:wasm": "cd src/wasm-engine && chmod +x build.sh && ./build.sh",
    "dev": "vite --config vite.ui.config.ts",
    "lint": "eslint --ext .ts,.tsx --ignore-pattern node_modules .",
    "lint:fix": "eslint --ext .ts,.tsx --ignore-pattern node_modules --fix .",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "watch": "npm run build:plugin -- --watch & npm run build:ui -- --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:browser:watch": "vitest --config vitest.browser.config.ts",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "author": "",
  "license": "",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@figma/eslint-plugin-figma-plugins": "*",
    "@figma/plugin-typings": "^1.121.0",
    "@tailwindcss/postcss": "^4.1.16",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__standalone": "^7.1.9",
    "@types/estraverse": "^5.1.7",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/browser-playwright": "^4.0.6",
    "@vitest/ui": "^4.0.6",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.0.10",
    "playwright": "^1.40.0",
    "postcss": "^8.5.6",
    "prettier": "3.6.2",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.3.2",
    "vite": "^7.1.12",
    "vite-plugin-singlefile": "^2.3.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.6"
  },
  "dependencies": {
    "@emotion/babel-plugin": "^11.13.5",
    "@emotion/css": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@twind/core": "^1.1.3",
    "@twind/preset-autoprefix": "^1.0.7",
    "@twind/preset-tailwind": "^1.1.4",
    "astring": "^1.9.0",
    "deep-object-diff": "^1.1.9",
    "estraverse": "^5.3.0",
    "highlight.js": "^11.11.1",
    "html-to-image": "^1.11.13",
    "jszip": "^3.10.1",
    "pixelmatch": "^7.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.11.0",
    "stable-hash": "^0.0.6",
    "sucrase": "^3.35.1"
  }
}
