{
  "name": "_",
  "version": "1.0.0",
  "type": "module",
  "description": "Your Figma Plugin",
  "main": "code.js",
  "scripts": {
    "build": "npm run build:plugin && npm run build:ui",
    "build:plugin": "vite build --config vite.plugin.config.ts",
    "build:ui": "vite build --config vite.ui.config.ts",
    "dev": "npm run build:plugin && vite build --watch",
    "lint": "eslint --ext .ts,.tsx --ignore-pattern node_modules .",
    "lint:fix": "eslint --ext .ts,.tsx --ignore-pattern node_modules --fix .",
    "watch": "npm run build:plugin -- --watch"
  },
  "author": "",
  "license": "",
  "devDependencies": {
    "@figma/eslint-plugin-figma-plugins": "*",
    "@figma/plugin-typings": "*",
    "@tailwindcss/postcss": "^4.1.16",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.54.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.3.2",
    "vite": "^7.1.12",
    "vite-plugin-singlefile": "^2.3.0"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
