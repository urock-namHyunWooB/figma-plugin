{
  "compilerOptions": {
    "target": "es6",
    "lib": ["es6"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "./src/plugin",
    "strict": true,
    "typeRoots": ["./node_modules/@types", "./node_modules/@figma"],
    "skipLibCheck": true
  },
  "include": ["src/plugin/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/ui"]
}
