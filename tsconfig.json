{
  "compilerOptions": {
    "target": "es6",
    "lib": ["es6", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "node",
    "outDir": "./dist",
    "strict": true,
    "typeRoots": ["./node_modules/@types", "./node_modules/@figma"],
    "skipLibCheck": true,
    "jsx": "react-jsx"
  },

  "include": ["src/plugin/**/*.ts", "src/ui/**/*.ts", "src/ui/**/*.tsx"],
  "exclude": ["dist"]
}
